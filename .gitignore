# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
functions/node_modules/

# Android signing — never commit these
android/key.properties
*.keystore
*.jks

# Test coverage output
coverage/
lcov.info

# Self-hosted server — secrets and runtime data
server/.env
server/firebase-service-account.json
server/*firebase-adminsdk*.json
server/node_modules/
server/uploads/
server/cloudflared.exe

# Flutter server config — contains local IP and secret
lib/config.dart