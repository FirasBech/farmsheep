<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup rules for Android 11 and below.
    Exclude sensitive credential files from auto-backup.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="FlutterSharedPreferences" />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
</full-backup-content>
