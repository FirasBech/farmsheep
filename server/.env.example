# ─────────────────────────────────────────────────────────────────────────────
# FarmSheep Server — copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Port the server listens on
PORT=3000

# The IP address of THIS machine on your local network (run `ipconfig` to find it)
SERVER_URL=http://192.168.1.100:3000

# Secret shared between this server and the Flutter app.
# Change this to any random string — must match kServerSecret in lib/config.dart
SERVER_SECRET=change-this-to-a-random-secret-string

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Primary provider (groq is free and fast)
AI_PROVIDER=groq
# Fallback provider if primary fails (optional)
AI_FALLBACK=anthropic

# API keys — only fill in the providers you want to use
GROQ_API_KEY=gsk_...
XAI_API_KEY=xai-...
DEEPSEEK_API_KEY=sk-...
MISTRAL_API_KEY=...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Firebase ────────────────────────────────────────────────────────────────
# Path to your Firebase service account JSON file
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
